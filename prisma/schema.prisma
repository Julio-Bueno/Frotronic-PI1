// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Drivers{
  id_driver String     @id @default(uuid())
  name      String     @unique
  note      String?
  schedules Schedule[]
}

model Passenger {
  id_passenger Int     @id @default(autoincrement())
  name         String?
}

model Vehicle {
  model     String      @id  @unique
  schedules Schedule[]
}

model Schedule {
  schedule_id  String    @id @default(uuid())
  departure    DateTime  
  destination  String
  driver       Drivers   @relation(fields: [driver_id], references: [name])
  driver_id    String
  vehicle      Vehicle   @relation(fields: [vehicle_id], references: [model])
  vehicle_id   String
  status       String    @default("pending")
  scheduler    User      @relation(fields: [scheduler_id], references: [id_user])
  scheduler_id String
}

model User {
  id_user     String     @id @default(uuid())
  password    String
  name        String     @unique
  createAt    DateTime   @default(now())
  description String?
  schedules   Schedule[]
}
